<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
  <selector>
    <item android:state_pressed="true" android:state_enabled="true">
      <set>
        <objectAnimator android:duration="@com.hintsolutions.raintv:integer/mtrl_btn_anim_duration_ms" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_translation_z_pressed" android:valueType="floatType" android:propertyName="translationZ" />
        <objectAnimator android:propertyName="elevation" android:duration="0" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_elevation" android:valueType="floatType" />
      </set>
    </item>
    <item android:state_hovered="true" android:state_enabled="true">
      <set>
        <objectAnimator android:valueType="floatType" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_translation_z_hovered_focused" android:duration="@com.hintsolutions.raintv:integer/mtrl_btn_anim_duration_ms" android:propertyName="translationZ" />
        <objectAnimator android:propertyName="elevation" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_elevation" android:duration="0" android:valueType="floatType" />
      </set>
    </item>
    <item android:state_focused="true" android:state_enabled="true">
      <set>
        <objectAnimator android:valueType="floatType" android:duration="@com.hintsolutions.raintv:integer/mtrl_btn_anim_duration_ms" android:propertyName="translationZ" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_translation_z_hovered_focused" />
        <objectAnimator android:valueType="floatType" android:propertyName="elevation" android:duration="0" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_elevation" />
      </set>
    </item>
    <item android:state_enabled="true">
      <set>
        <objectAnimator android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_translation_z_base" android:valueType="floatType" android:duration="@com.hintsolutions.raintv:integer/mtrl_btn_anim_duration_ms" android:startDelay="@com.hintsolutions.raintv:integer/mtrl_btn_anim_delay_ms" android:propertyName="translationZ" />
        <objectAnimator android:duration="0" android:valueType="floatType" android:propertyName="elevation" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_elevation" />
      </set>
    </item>
    <item>
      <set>
        <objectAnimator android:valueType="floatType" android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_disabled_translation_z" android:duration="0" android:propertyName="translationZ" />
        <objectAnimator android:valueTo="@com.hintsolutions.raintv:dimen/mtrl_extended_fab_disabled_elevation" android:duration="0" android:propertyName="elevation" android:valueType="floatType" />
      </set>
    </item>
  </selector>
</set>