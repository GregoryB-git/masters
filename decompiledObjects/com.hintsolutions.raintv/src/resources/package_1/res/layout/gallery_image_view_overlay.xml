<?xml version='1.0' encoding='utf-8' ?>
<merge android:orientation="vertical"
       android:layout_width="fill_parent"
       android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/close"
             android:clickable="true"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginLeft="8.0dp"
             android:layout_marginTop="8.0dp"
             raintv:srcCompat="@0x7f0800af" />
  <TextView android:gravity="center_horizontal"
            android:layout_gravity="top"
            android:id="@id/position"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dp"
            android:layout_alignParentTop="false"
            android:layout_alignParentBottom="false" />
  <ImageView android:id="@id/share"
             android:clickable="true"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginTop="8.0dp"
             android:layout_marginRight="8.0dp"
             android:layout_alignParentRight="true"
             raintv:srcCompat="@0x7f0801cc" />
  <LinearLayout android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="@id/scrollview_limit_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true">
    <ScrollView android:layout_gravity="bottom"
                android:id="@id/scrollview"
                android:background="#80000000"
                android:paddingLeft="@dimen/content_padding"
                android:paddingRight="@dimen/content_padding"
                android:scrollbars="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:paddingTop="@dimen/content_padding"
                    android:paddingBottom="@dimen/content_padding"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="12.0sp"
                  android:textStyle="italic"
                  android:textColor="#9d9d9d"
                  android:ellipsize="end"
                  android:id="@id/author"
                  android:paddingBottom="8.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:text="@string/ph_author" />
        <TextView android:textColor="#ffffff"
                  android:id="@id/description"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:text="@string/ph_news_text" />
      </LinearLayout>
    </ScrollView>
  </LinearLayout>
</merge>