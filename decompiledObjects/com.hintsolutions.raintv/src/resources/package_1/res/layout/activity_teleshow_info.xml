<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/root"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <com.google.android.material.appbar.AppBarLayout android:background="@color/color_new_toolbar_background"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <include android:id="@id/toolbar"
             layout="@layout/toolbar_new" />
  </com.google.android.material.appbar.AppBarLayout>
  <ScrollView android:layout_width="fill_parent"
              android:layout_height="wrap_content">
    <com.hintsolutions.raintv.views.CustomFontTextView android:textSize="16.0sp"
                          android:textColor="@color/color_new_text_black"
                          android:id="@id/text"
                          android:paddingLeft="@dimen/content_padding"
                          android:paddingTop="@dimen/content_padding"
                          android:paddingRight="@dimen/content_padding"
                          android:paddingBottom="@dimen/content_padding"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:text="@string/ph_news_text"
                          android:lineSpacingExtra="8.0sp"
                          raintv:font_face="@string/font_roboto_regular" />
  </ScrollView>
</LinearLayout>