<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/search_placeholders_container"
              android:background="@color/common_search_suggestion"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <com.hintsolutions.raintv.views.CustomFontTextView android:textSize="18.0sp"
                        android:textColor="#000"
                        android:id="@id/header"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="Сейчас ищут"
                        raintv:font_face="@string/font_roboto_regular" />
  <RelativeLayout android:background="@color/common_search_suggestion"
                  android:paddingLeft="12.0dp"
                  android:paddingRight="12.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="58.0dp">
    <ImageView android:id="@id/clock_icon"
               android:layout_width="32.0dp"
               android:layout_height="fill_parent"
               android:src="@0x7f08010a"
               android:scaleType="centerInside"
               android:layout_alignParentTop="true"
               android:layout_alignParentBottom="true" />
    <com.hintsolutions.raintv.views.CustomFontTextView android:textSize="16.0sp"
                          android:textColor="#000"
                          android:id="@id/name"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginLeft="18.0dp"
                          android:text="@string/ph_news_name"
                          android:singleLine="true"
                          android:layout_toRightOf="@id/clock_icon"
                          android:layout_above="@android:id/text2"
                          android:layout_centerVertical="true"
                          android:layout_toEndOf="@id/clock_icon"
                          android:layout_alignParentEnd="true"
                          raintv:font_face="@string/font_roboto_regular"
                          style="?android:attr/dropDownItemStyle" />
  </RelativeLayout>
</LinearLayout>