                            android:layout_centerVertical="true"
                            raintv:font_face="@string/font_roboto_regular"
                            style="@style/Base.TextAppearance.AppCompat.Title" />
    </RelativeLayout>
  </LinearLayout>
  <Button android:textColor="@color/white"
