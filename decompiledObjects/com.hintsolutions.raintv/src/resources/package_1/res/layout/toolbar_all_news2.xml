<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:theme="@style/NewTheme"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:background="?attr/colorPrimary"
              android:layout_width="fill_parent"
              android:layout_height="?attr/actionBarSize" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <RelativeLayout android:id="@id/menuToggleHolder"
                  android:clickable="true"
                  android:layout_width="56.0dp"
                  android:layout_height="56.0dp"
                  android:layout_centerVertical="true"
                  style="@style/SelectableFull">
    <ImageView android:id="@id/imageView8"
               android:background="?attr/selectableItemBackgroundBorderless"
               android:paddingLeft="8.0dp"
               android:paddingTop="1.0dp"
               android:paddingRight="8.0dp"
               android:clickable="false"
               android:layout_width="48.0dp"
               android:layout_height="48.0dp"
               android:src="@0x7f08013c"
               android:layout_centerInParent="true"
               android:paddingHorizontal="8.0dp" />
    <TextView android:textSize="10.0sp"
              android:gravity="center"
              android:id="@id/toggleBadgeTextView"
              android:background="@drawable/white_badge_background"
              android:visibility="gone"
              android:layout_width="20.0dp"
              android:layout_height="20.0dp"
