<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingLeft="6.0dp"
              android:paddingRight="6.0dp"
              android:clipChildren="false"
              android:clipToPadding="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <androidx.cardview.widget.CardView android:id="@id/cardView"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        raintv:cardCornerRadius="5.0dp"
                        raintv:cardElevation="3.0dp"
                        raintv:cardUseCompatPadding="true"
                        raintv:contentPadding="0.0dp">
    <LinearLayout android:orientation="vertical"
                  android:id="@id/rootLayout"
                  android:clickable="true"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  style="@style/Selectable">
      <RelativeLayout android:layout_width="fill_parent"
                      android:layout_height="200.0dp">
        <ImageView android:id="@id/thumbnailImageView"
                   android:background="@color/colorPrimary"
                   android:layout_width="fill_parent"
                   android:layout_height="fill_parent"
                   android:scaleType="centerCrop" />
        <TextView android:textColor="@color/white"
                  android:gravity="center"
                  android:id="@id/moderationBackground"
                  android:background="@color/colorPrimary"
                  android:padding="@dimen/default_padding"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:layout_centerInParent="true"
                  android:alpha="0.6" />
        <ImageView android:layout_width="fill_parent"
                   android:layout_height="fill_parent"
                   android:src="@drawable/gradient"
                   android:scaleType="fitXY"
                   android:alpha="0.8" />
        <TextView android:textColor="@color/white"
                  android:id="@id/projectAuthorLabel"
                  android:background="@color/colorPrimary"
                  android:paddingLeft="@dimen/default_padding"
                  android:paddingTop="8.0dp"
                  android:paddingRight="@dimen/default_padding"
                  android:paddingBottom="8.0dp"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_margin="@dimen/default_padding"
                  android:text="@string/label_project_author"
                  android:textAllCaps="true" />
        <TextView android:textColor="@color/white"
                  android:gravity="center"
                  android:id="@id/moderation"
                  android:padding="@dimen/default_padding"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:text="@string/video_on_moderation"
                  android:layout_centerInParent="true" />
      </RelativeLayout>
      <LinearLayout android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@id/actionsLayout"
                    android:padding="@dimen/default_padding"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <LinearLayout android:gravity="center"
                      android:orientation="horizontal"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginLeft="8.0dp"
                      android:layout_marginRight="8.0dp">
          <ImageView android:id="@id/imageView4"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@0x7f0802c0" />
          <TextView android:textColor="@color/rc_grey"
                    android:id="@id/viewsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8.0dp"
                    android:text="0" />
        </LinearLayout>
        <LinearLayout android:gravity="center"
                      android:orientation="horizontal"
                      android:id="@id/likeLayout"
                      android:paddingLeft="8.0dp"
                      android:paddingRight="8.0dp"
                      android:clickable="true"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content">
          <ImageView android:id="@id/likeImageView"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@0x7f0802bb" />
          <TextView android:textColor="@color/rc_grey"
                    android:id="@id/likesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8.0dp"
                    android:text="0" />
        </LinearLayout>
        <LinearLayout android:gravity="center"
                      android:orientation="horizontal"
                      android:id="@id/shareLayout"
                      android:paddingLeft="8.0dp"
                      android:paddingRight="8.0dp"
                      android:clickable="true"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content">
          <ImageView android:id="@id/imageView6"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@0x7f0802be" />
          <TextView android:textColor="@color/rc_grey"
                    android:id="@id/shareCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8.0dp"
                    android:text="0" />
        </LinearLayout>
        <LinearLayout android:gravity="center"
                      android:orientation="horizontal"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginLeft="8.0dp"
                      android:layout_marginRight="8.0dp">
          <ImageView android:id="@id/imageView7"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@0x7f0802b8" />
          <TextView android:textColor="@color/rc_grey"
                    android:id="@id/commentsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8.0dp"
                    android:text="0" />
        </LinearLayout>
      </LinearLayout>
    </LinearLayout>
  </androidx.cardview.widget.CardView>
  <LinearLayout android:orientation="vertical"
                android:id="@id/adLayout"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/default_padding"
                android:layout_marginBottom="@dimen/default_padding" />
  <LinearLayout android:orientation="vertical"
                android:padding="@dimen/default_padding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentBottom="true">
    <TextView android:textColor="#77343434"
              android:id="@id/info"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="New Text"
              android:alpha="0.8"
              android:textAllCaps="true"
              android:fontFamily="sans-serif-medium" />
    <TextView android:textSize="@dimen/text_size_large"
              android:textColor="#77343434"
              android:id="@id/name"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="New Text" />
  </LinearLayout>
</LinearLayout>