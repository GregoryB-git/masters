<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@color/black"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <RelativeLayout android:id="@id/videoContainer"
                  android:clickable="false"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:layout_centerInParent="true">
    <com.hintsolutions.raintv.video.ExoVideoView android:id="@id/video"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_alignParentLeft="true"
                          android:layout_alignParentTop="true"
                          android:layout_alignParentRight="true"
                          android:layout_alignParentBottom="true"
                          raintv:useDefaultControls="true" />
  </RelativeLayout>
  <TextView android:textSize="18.0sp"
            android:textColor="#ffffff"
            android:id="@id/program_name"
            android:paddingLeft="@dimen/content_padding"
            android:paddingTop="@dimen/content_padding"
            android:paddingRight="@dimen/content_padding"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/ph_program_name"
            android:layout_below="@id/videoContainer"
            android:layout_alignParentLeft="true"
            android:layout_alignParentRight="true" />
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/castLayout"
                android:background="@color/color_rain_text_black"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
    <ImageView android:layout_width="128.0dp"
               android:layout_height="128.0dp"
               raintv:ico_color="@color/white"
               raintv:ico_icon="gmd-cast-connected"
               raintv:ico_size="128.0dp" />
    <TextView android:textSize="22.0sp"
              android:gravity="center"
              android:id="@id/castLabel"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_margin="@dimen/default_padding"
              android:fontFamily="sans-serif-light" />
  </LinearLayout>
  <include android:id="@id/toolbar"
           layout="@layout/toolbar" />
  <fragment android:id="@id/cast_mini_controller"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            raintv:castShowImageThumbnail="true"
            raintv:castSubtitleTextAppearance="@style/CastMiniController.Subtitle"
            raintv:castTitleTextAppearance="@style/CastMiniController.Title"
            class="tvrain.cast.CustomMiniControllerFragment" />
</RelativeLayout>