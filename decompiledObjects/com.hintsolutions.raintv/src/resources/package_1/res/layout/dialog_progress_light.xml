<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:raintv="http://schemas.android.com/apk/res-auto">
  <com.pnikosis.materialishprogress.ProgressWheel android:id="@id/progress_wheel"
                        android:layout_width="80.0dp"
                        android:layout_height="80.0dp"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        raintv:matProg_barColor="@color/accent"
                        raintv:matProg_progressIndeterminate="true" />
  <TextView android:textSize="16.0sp"
            android:textColor="@color/black"
            android:id="@id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25.0dp"
            android:text="@string/please_wait"
            android:layout_below="@id/progress_wheel"
            android:layout_centerHorizontal="true" />
</RelativeLayout>