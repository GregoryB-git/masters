<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <include android:id="@id/toolbar"
           layout="@layout/toolbar" />
  <LinearLayout android:orientation="vertical"
                android:padding="@dimen/padding"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <com.rengwuxian.materialedittext.MaterialEditText android:id="@id/email"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginBottom="@dimen/vertical_spacing"
                          android:hint="@string/hint_email"
                          android:singleLine="true"
                          android:inputType="textEmailAddress"
                          style="@style/MaterialEditText.Accent" />
    <Button android:id="@id/recovery"
            android:text="Восстановить"
            style="@style/Button.Pink" />
  </LinearLayout>
</LinearLayout>